{
    "slug": "vps_connection_details",
    "name": "VPS Connection Details",
    "description": "Email sent when a VPS has been provisioned with connection details (hostname, IP, SSH user, password)",
    "category": "provisioning",
    "channels": {
        "email": {
            "template_path": "vps_connection_details",
            "default_subject": "Your VPS is ready - Connection details"
        }
    },
    "variables": [
        {
            "name": "hostname",
            "description": "VPS hostname",
            "source": "Passed in data dict",
            "example": "vps-12345.example.com",
            "required": true
        },
        {
            "name": "ip_address",
            "description": "VPS IP address",
            "source": "Passed in data dict",
            "example": "192.0.2.1",
            "required": true
        },
        {
            "name": "ssh_user",
            "description": "SSH login user",
            "source": "Passed in data dict",
            "example": "root",
            "required": true
        },
        {
            "name": "ssh_port",
            "description": "SSH port",
            "source": "Passed in data dict",
            "example": "22",
            "required": true
        },
        {
            "name": "root_password",
            "description": "VPS root password (sensitive)",
            "source": "Passed in data dict",
            "example": "",
            "required": true
        }
    ]
}
